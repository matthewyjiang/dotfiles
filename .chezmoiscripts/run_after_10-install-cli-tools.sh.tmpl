{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
#!/bin/sh
set -u

# Generated by chezmoi from .chezmoiscripts/run_after_10-install-cli-tools.sh.tmpl.
# Re-runs on every `chezmoi apply`. Installs missing tools, checks minimum
# versions where configured, and uses tool-specific upstream installers when the
# OS package is too old.
# chezmoi os: {{ .chezmoi.os }}{{ if eq .chezmoi.os "linux" }}; os-release id: {{ get .chezmoi.osRelease "id" | default "unknown" }}; id_like: {{ get .chezmoi.osRelease "idLike" | default "" }}{{ end }}

log() { printf '%s\n' "chezmoi cli-tools: $*"; }
has() { command -v "$1" >/dev/null 2>&1; }

sudo_cmd=""
if [ "$(id -u)" -ne 0 ]; then
  sudo_cmd="sudo"
fi

version_ge() {
  actual="$1"
  minimum="$2"
  if has python3; then
    python3 - "$actual" "$minimum" <<'PY'
import re, sys

def parts(v):
    return [int(x) for x in re.findall(r'\d+', v)[:3]] + [0, 0, 0]

sys.exit(0 if parts(sys.argv[1])[:3] >= parts(sys.argv[2])[:3] else 1)
PY
  else
    [ "$(printf '%s\n%s\n' "$minimum" "$actual" | sort -V | head -n 1)" = "$minimum" ]
  fi
}

installed_version() {
  command_name="$1"
  case "$command_name" in
    zoxide) zoxide --version 2>/dev/null | awk '{print $2}' | sed 's/^v//; s/-.*$//' ;;
    starship) starship --version 2>/dev/null | awk '{print $2}' ;;
    fzf) fzf --version 2>/dev/null | awk '{print $1}' ;;
    eza) eza --version 2>/dev/null | awk 'NR == 1 {print $2}' | sed 's/^v//' ;;
    bat) bat --version 2>/dev/null | awk '{print $2}' ;;
    vivid) vivid --version 2>/dev/null | awk '{print $2}' ;;
    nvim) nvim --version 2>/dev/null | awk 'NR == 1 {print $2}' | sed 's/^v//' ;;
    fastfetch) fastfetch --version 2>/dev/null | awk '{print $2}' ;;
    *) "$command_name" --version 2>/dev/null | awk 'NR == 1 {for (i=1; i<=NF; i++) if ($i ~ /^v?[0-9]/) {gsub(/^v/, "", $i); print $i; exit}}' ;;
  esac
}

package_candidate_version() {
  package_name="$1"
  if has apt-cache; then
    apt-cache policy "$package_name" 2>/dev/null | awk '/Candidate:/ && $2 != "(none)" {print $2; exit}' | sed 's/^[0-9]*://; s/-.*$//; s/+.*$//'
  elif has brew; then
    brew info --json=v2 "$package_name" 2>/dev/null | python3 -c 'import json,sys; d=json.load(sys.stdin); f=(d.get("formulae") or [{}])[0]; print((f.get("versions") or {}).get("stable", ""))' 2>/dev/null
  elif has dnf; then
    dnf --quiet repoquery --qf '%{version}' "$package_name" 2>/dev/null | head -n 1
  elif has pacman; then
    pacman -Si "$package_name" 2>/dev/null | awk -F: '/^Version/ {gsub(/^[ \t]+/, "", $2); print $2; exit}' | sed 's/-.*$//'
  elif has zypper; then
    zypper --quiet info "$package_name" 2>/dev/null | awk -F: '/^Version/ {gsub(/^[ \t]+/, "", $2); print $2; exit}'
  elif has apk; then
    apk info -a "$package_name" 2>/dev/null | awk -F- 'NR == 1 {print $2; exit}'
  fi
}

can_query_packages() {
  has apt-cache || has brew || has dnf || has pacman || has zypper || has apk
}

needs_tool() {
  command_name="$1"
  minimum_version="$2"

  case "$command_name" in
    zsh-syntax-highlighting)
      [ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] || return 0
      ;;
    *)
      has "$command_name" || return 0
      ;;
  esac

  [ -n "$minimum_version" ] || return 1
  actual_version="$(installed_version "$command_name")"
  [ -n "$actual_version" ] || return 0
  version_ge "$actual_version" "$minimum_version" && return 1
  return 0
}

missing_pkgs=""
upstream_tools=""
add_requested() {
  command_name="$1"
  package_name="$2"
  minimum_version="${3:-}"

  needs_tool "$command_name" "$minimum_version" || return 0

  candidate_version="$(package_candidate_version "$package_name")"
  if [ -z "$candidate_version" ] && can_query_packages; then
    log "$package_name is not available from the package manager; skipping"
    return 0
  fi

  if [ -n "$minimum_version" ]; then
    log "$package_name candidate version: $candidate_version; minimum: $minimum_version"
    if ! version_ge "$candidate_version" "$minimum_version"; then
      upstream_tools="${upstream_tools}${upstream_tools:+ }$command_name"
      return 0
    fi
  fi

  missing_pkgs="${missing_pkgs}${missing_pkgs:+ }$package_name"
}

{{- range (index .cliTools .chezmoi.os) }}
add_requested {{ .command | quote }} {{ .package | quote }} {{ (get . "minVersion" | default "") | quote }}
{{- end }}

install_with_brew() {
  if ! has brew; then
    log "homebrew is not installed; skipping: $missing_pkgs"
    return 0
  fi
  brew install $missing_pkgs || log "some homebrew installs failed"
}

install_linux() {
  if has apt-get; then
    $sudo_cmd apt-get update
    for pkg in $missing_pkgs; do
      $sudo_cmd apt-get install -y "$pkg" || log "apt could not install $pkg"
    done
  elif has dnf; then
    for pkg in $missing_pkgs; do
      $sudo_cmd dnf install -y "$pkg" || log "dnf could not install $pkg"
    done
  elif has pacman; then
    $sudo_cmd pacman -Sy --needed --noconfirm $missing_pkgs || log "pacman could not install one or more packages"
  elif has zypper; then
    $sudo_cmd zypper --non-interactive install --no-recommends $missing_pkgs || log "zypper could not install one or more packages"
  elif has apk; then
    $sudo_cmd apk add $missing_pkgs || log "apk could not install one or more packages"
  elif has brew; then
    install_with_brew
  else
    log "no supported package manager found; skipping: $missing_pkgs"
  fi
}

install_zoxide_upstream() {
  install_dir="$HOME/.local/bin"
  mkdir -p "$install_dir"

  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' EXIT HUP INT TERM

  latest="$(curl -fsSL https://api.github.com/repos/ajeetdsouza/zoxide/releases/latest | awk -F'"' '/"tag_name"/ {print $4; exit}')"
  version="${latest#v}"
  arch="$(uname -m)"
  case "$arch" in
    x86_64|amd64) target="x86_64-unknown-linux-musl" ;;
    aarch64|arm64) target="aarch64-unknown-linux-musl" ;;
    armv7l) target="armv7-unknown-linux-musleabihf" ;;
    *) log "unsupported zoxide upstream architecture: $arch"; return 0 ;;
  esac

  url="https://github.com/ajeetdsouza/zoxide/releases/download/$latest/zoxide-$version-$target.tar.gz"
  log "installing zoxide $version from upstream release"
  curl -fsSL "$url" -o "$tmpdir/zoxide.tar.gz" || { log "failed to download $url"; return 0; }
  tar -xzf "$tmpdir/zoxide.tar.gz" -C "$tmpdir" zoxide || { log "failed to unpack zoxide"; return 0; }
  install -m 0755 "$tmpdir/zoxide" "$install_dir/zoxide" || log "failed to install zoxide to $install_dir"
}

if [ -n "$missing_pkgs" ]; then
  log "packages to install: $missing_pkgs"
  case {{ .chezmoi.os | quote }} in
    darwin) install_with_brew ;;
    linux) install_linux ;;
  esac
fi

for tool in $upstream_tools; do
  case "$tool" in
    zoxide) install_zoxide_upstream ;;
    *) log "no upstream installer configured for $tool" ;;
  esac
done

if [ -z "$missing_pkgs" ] && [ -z "$upstream_tools" ]; then
  log "all requested tools already installed and satisfy minimum versions"
fi
{{- end -}}
